# Required: private key of the wallet that will deploy the contract.
# Export this from MetaMask. NEVER commit the real value.
PRIVATE_KEY=0x...

# Optional: only needed if you want to verify on Arbiscan.
# This is the Etherscan V2 unified API key — one key works across every
# Etherscan-family explorer (Arbiscan, Basescan, Polygonscan, ...).
# Get one at https://etherscan.io/myaccount
# Sourcify verification works WITHOUT any API key.
ETHERSCAN_API_KEY=
